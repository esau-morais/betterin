# Database
DATABASE_URL=postgres://better_in:better_in_dev@localhost:5432/better_in

# Redis
REDIS_URL=redis://localhost:6379

# Site (VITE_ prefix exposes to client for OG/meta tags)
VITE_SITE_URL=http://localhost:3000

# Better Auth
BETTER_AUTH_SECRET=change-me-in-production-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000

# APNs (iOS Push Notifications)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY_PATH=./apns.p8
APNS_BUNDLE_ID=com.betterin.app
APNS_ENV=sandbox

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=Better In <noreply@yourdomain.com>

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth — LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Cloudflare R2 (file storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=better-in
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# OpenAI (content moderation)
OPENAI_API_KEY=

# KWS (Kids Web Services — age verification & parental consent)
KWS_CLIENT_ID=
KWS_API_KEY=
KWS_WEBHOOK_SECRET=
KWS_VERIFICATION_RESPONSE_SECRET=

# Admin (ML pipeline management)
ADMIN_SECRET=change-me-in-production
