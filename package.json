    "ml:train": ".venv/bin/python scripts/ml/train.py",
    "ml:evaluate": "bun run scripts/ml/evaluate.ts",
    "ml:pipeline": "bun run scripts/ml/pipeline.ts",
    "ml:status": "bun run scripts/ml/status.ts",
    "generate:gradient": "npx tsx scripts/generate-gradient-snapshots.ts",
    "generate:icons": "bun run scripts/generate-icons.ts",
    "email:dev": "email dev -p 3030"
  },
